# Copy this file to .env and fill in real values. Never commit .env.

# Supabase Postgres — pooled connection (PgBouncer, port 6543), used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase Postgres — direct connection (port 5432), used by Prisma Migrate / introspection.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase project API (used later for Realtime / Storage / Auth helpers)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# NextAuth (Phase 2)
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""

# LINE Login channel (Phase 2) — create a "LINE Login" channel at
# https://developers.line.biz/console/ and set the callback URL to
# <NEXTAUTH_URL>/api/auth/callback/line
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""

# LINE channel id used to verify ID tokens from the LIFF booking page (multi-channel-booking-
# prompt.md, Phase 2/3) — POST /api/bookings checks any `channel: "LINE"` request's ID token
# against this as the expected `aud`. Usually the same channel as LINE_CLIENT_ID above, but kept
# as its own var since a LIFF app can be registered under a different LINE Login channel.
LINE_CHANNEL_ID=""

# LIFF app id for the booking mini-app at app/liff/booking (multi-channel-booking-prompt.md,
# Phase 3) — from the LIFF tab of the same LINE Login channel as LINE_CHANNEL_ID above. Public
# (NEXT_PUBLIC_) because liff.init() runs in the browser; it only identifies which LIFF app is
# loading, it is not a secret.
NEXT_PUBLIC_LIFF_ID=""

# LINE Messaging API channel (Phase 9, notifications) — a *separate* channel from LINE Login
# above, created under the same LINE Official Account. Get the token from the "Messaging API"
# tab of that channel in the LINE Developers console. LINE Notify was shut down in March 2025,
# so this push-message API is the only remaining way to message a customer/owner proactively.
# Leave blank to disable notifications (they'll just log to the server console instead).
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=""

# WhatsApp Flow endpoint (multi-channel-booking-prompt.md, Phase 4) — POST /api/whatsapp/flow
# implements Meta's WhatsApp Flows Data Exchange encryption. Generate an RSA keypair (2048-bit
# minimum) with `openssl genrsa -aes256 -out private.pem 2048` (the -aes256 + a passphrase is
# recommended), upload the matching public key for your WhatsApp Business Encryption via the
# Graph API (`POST /<PHONE_NUMBER_ID>/whatsapp_business_encryption`), and paste the private key's
# PEM contents here (keep the literal newlines, e.g. via a multiline .env value or `\n` escapes
# depending on how your host reads env vars).
WA_FLOW_PRIVATE_KEY=""
# Passphrase for the private key above, if it was generated with one (recommended). Leave blank
# only if the key is unencrypted.
WA_FLOW_PASSPHRASE=""
# Our own secret for signing the flow's intra-session state_token (branch/service/date/time
# selections threaded across screens) and, once Phase 5 exists, the flow_token that carries the
# verified wa_id. Never sent to Meta or the client — purely first-party HMAC signing.
# Generate with: openssl rand -base64 32
WA_FLOW_TOKEN_SECRET=""

# Shared secret for the /api/cron/* routes (daily sales summary + booking reminders).
# Vercel automatically sends `Authorization: Bearer $CRON_SECRET` to its own Cron Jobs when an
# env var with this exact name is set; the GitHub Actions reminder workflow
# (.github/workflows/reminders.yml) sends the same header using a repo secret of the same value.
# Generate with: openssl rand -base64 32
CRON_SECRET=""
